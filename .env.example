# Configuration de l'automatisation Paperless.
# Copier ce fichier vers .env et remplir les valeurs. NE JAMAIS commiter .env.
#
# Déploiement : placer .env à côté de config.py (ex. /opt/paperless/scripts/.env),
# lisible uniquement par l'utilisateur qui exécute le hook (chmod 600).

# Token API Paperless-ngx (Paramètres → onglet « API » → régénérer au besoin).
# OBLIGATOIRE. À régénérer si ce token a déjà été exposé (code, historique git, etc.).
PAPERLESS_TOKEN=

# URL de l'API Paperless (défaut : http://localhost:8000/api).
# NB: utiliser PAPERLESS_API_URL et NON PAPERLESS_URL — ce dernier est un nom
# réservé par Paperless-ngx (URL publique sans /api) qu'il injecte dans
# l'environnement du hook post-consume, ce qui casserait les appels API.
PAPERLESS_API_URL=http://localhost:8000/api

# Chemin du binaire claude CLI (défaut : /root/.local/bin/claude).
CLAUDE_BIN=/root/.local/bin/claude

# ─── Loop autonome (loop.sh) — optionnel ──────────────────────────────────────
# Webhook de notification (Home Assistant, etc.). Vide = pas de notification.
LOOP_HA_WEBHOOK=
# Modèle utilisé par le loop (défaut : claude-fable-5).
LOOP_MODEL=claude-fable-5
